{
  "compilerOptions": {
    "checkJs": true,
    "strict": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2023",
    "lib": ["es2023"],
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.mjs", "tests/**/*.mjs"]
}
